generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Main Quizzes ─────────────────────────────────────────────
model Quiz {
  id          String    @id @default(cuid())
  title       String
  description String?
  timeLimit   Int
  questions   String    // JSON QuizQuestion[]
  category    String    @default("general") // see src/lib/categories.ts
  exam        String    @default("cds")     // "afcat" | "cds"
  paperType   String    @default("chapter") // "chapter" | "mock"
  isRetry     Boolean   @default(false)     // system-generated retry quiz
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attempts    Attempt[]
}

// ── Users (auth) ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user") // "admin" | "user"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attempt {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String?  // null on legacy rows from before auth
  sessionId   String
  answers     String   // JSON { [questionIndex]: selectedOptionIndex | null }
  score       Float    // can be fractional due to 1/3 negative marking
  totalScore  Float
  timeTaken   Int
  isRetry     Boolean  @default(false)
  completedAt DateTime @default(now())
  startedAt   DateTime

  @@index([userId])
  // Race guard for the "one attempt per quiz per user" rule. SQLite treats NULL
  // as distinct, so legacy rows (userId IS NULL) and retry quizzes (each retry
  // creates a fresh quizId) don't conflict.
  @@unique([userId, quizId, isRetry])
}

// ── English: Vocabulary ──────────────────────────────────────
model VocabSet {
  id          String      @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime    @default(now())
  words       VocabWord[]
  attempts    VocabAttempt[]
}

model VocabWord {
  id          String    @id @default(cuid())
  setId       String
  set         VocabSet  @relation(fields: [setId], references: [id], onDelete: Cascade)
  word        String
  meaning     String
  example     String?   // example sentence
  mnemonic    String?   // AI memory trick
  tips        String?   // AI learning tip
  partOfSpeech String?  // noun, verb, adj...
  createdAt   DateTime  @default(now())
}

model VocabAttempt {
  id          String   @id @default(cuid())
  setId       String
  set         VocabSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  userId      String?
  sessionId   String
  wrongWordIds String  // JSON string[] of VocabWord IDs answered wrong
  score       Int
  total       Int
  timeTaken   Int
  completedAt DateTime @default(now())

  @@index([userId])
}

// ── English: Grammar (DRR format) ───────────────────────────
model GrammarRule {
  id           String           @id @default(cuid())
  title        String
  topic        String
  rule         String
  memoryTrick  String?
  examples     String           // JSON: { correct: string[], wrong: string[] }
  examTraps    String?
  questions    String?          // JSON QuizQuestion[]
  createdAt    DateTime         @default(now())
  attempts     GrammarAttempt[]
}

model GrammarAttempt {
  id          String      @id @default(cuid())
  ruleId      String
  rule        GrammarRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId      String?
  sessionId   String
  wrongIds    String      // JSON number[] — 0-based indices of questions answered wrong
  score       Int
  total       Int
  timeTaken   Int
  completedAt DateTime    @default(now())

  @@index([userId])
}

// ── AI 1-pager notes (1 page per 20 input pages) ─────────────
model NoteSet {
  id          String   @id @default(cuid())
  subject     String   // "english" | "physics" | "chemistry" | "biology" | "maths" | "general"
  title       String
  summary     String?
  sections    String   // JSON: { heading: string, points: string[] }[]
  sourcePages Int
  targetPages Int
  createdAt   DateTime @default(now())
}
