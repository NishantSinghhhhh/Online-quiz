{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/ai/extract/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/upload/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/generate/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/extract-vocab/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/extract-grammar/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/summarize-notes/route.ts": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
